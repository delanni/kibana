{
  "compilerOptions": {
    "strict": true,
    "module": "commonjs",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "target": "es2021",
    "lib": ["es2021"],
    "types": ["node", "jest"],
    "paths": {
      "#pipeline-utils": ["./pipeline-utils/index.ts"],
      "#pipeline-utils/*": ["./pipeline-utils/*"]
    }
  },
  "include": ["src/**/*.test.ts"]
}
